<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 헤더 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MMS → n8n 전달기"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="초기화 중..."
            android:textSize="13sp"
            android:paddingBottom="16dp"
            android:textColor="#666666" />

        <!-- 권한 상태 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="권한 상태"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPermissionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="확인 중..."
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 웹훅 설정 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="n8n 웹훅 설정"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:textColor="#333333" />

                <!-- 웹훅 URL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="웹훅 URL"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/etWebhookUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://n8n.n8n-content.store/webhook/MMS-receiver"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <!-- 시크릿 키 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="시크릿 키 (선택사항)"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/etWebhookSecret"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="X-Webhook-Secret 헤더 값"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <!-- 이미지 전송 스위치 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="이미지 포함 전송 (Base64)"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchSendImages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <!-- 버튼들 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSaveSettings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="저장"
                        android:backgroundTint="#1565C0" />

                    <Button
                        android:id="@+id/btnTestWebhook"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="연결 테스트"
                        android:backgroundTint="#388E3C" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 서비스 제어 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="서비스 제어"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:textColor="#333333" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnStartService"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="서비스 시작"
                        android:backgroundTint="#388E3C" />

                    <Button
                        android:id="@+id/btnStopService"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="서비스 중지"
                        android:backgroundTint="#C62828" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 전체 MMS 검색 & 전송 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="전체 MMS 검색 &amp; 전송"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="2dp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="저장된 MMS를 n8n으로 일괄 전송합니다"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:paddingBottom="12dp" />

                <!-- 전송 범위 선택 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전송 범위: "
                        android:textSize="14sp"
                        android:textColor="#444444" />

                    <Spinner
                        android:id="@+id/spinnerMmsLimit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- MMS 총 개수 표시 -->
                <TextView
                    android:id="@+id/tvMmsCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#777777"
                    android:layout_marginBottom="10dp" />

                <!-- 진행 상황 프로그레스바 -->
                <ProgressBar
                    android:id="@+id/progressBarBatch"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:visibility="gone"
                    android:layout_marginBottom="4dp" />

                <!-- 진행 상태 텍스트 -->
                <TextView
                    android:id="@+id/tvBatchStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp" />

                <!-- 전송 후 삭제 옵션 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFF3E0"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp">

                    <CheckBox
                        android:id="@+id/checkBoxDeleteAfterSend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="전송 완료된 MMS 기기에서 삭제"
                        android:textSize="14sp"
                        android:textColor="#E65100"
                        android:textStyle="bold"
                        android:checked="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠ 삭제된 MMS는 복구할 수 없습니다. 서비스 자동 감지는 삭제하지 않습니다."
                        android:textSize="11sp"
                        android:textColor="#BF360C"
                        android:paddingTop="2dp" />
                </LinearLayout>

                <!-- 버튼들 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSendAllMms"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="검색 &amp; 전송"
                        android:backgroundTint="#7B1FA2" />

                    <Button
                        android:id="@+id/btnCancelBatch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="취소"
                        android:backgroundTint="#757575"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 로그 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="이벤트 로그"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="8dp"
                    android:textColor="#333333" />

                <ScrollView
                    android:id="@+id/scrollViewLog"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:background="#F0F0F0"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tvLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textColor="#333333" />
                </ScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
